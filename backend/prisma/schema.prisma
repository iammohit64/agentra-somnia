generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

//////////////////////////////////////////////////
// ENUMS
//////////////////////////////////////////////////

enum AgentStatus {
  draft
  active
  inactive
  busy
  offline
}

enum AgentCategory {
  Analysis
  Development
  Security
  Data
  NLP
  Web3
  Other
}

enum AgentTier {
  Standard
  Professional
  Enterprise
}

enum TransactionType {
  deploy
  purchase_access
  upvote
  call
  agent_to_agent
}

enum TransactionStatus {
  pending
  confirmed
  failed
}

enum InteractionStatus {
  success
  failed
  timeout
}

//////////////////////////////////////////////////
// USER
//////////////////////////////////////////////////

model User {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  walletAddress String   @unique
  nonce         String   @default(cuid())

  totalRevenue  String   @default("0") // in wei

  createdAt     DateTime @default(now())
  lastSeen      DateTime @default(now())

  agents        Agent[]
  transactions  Transaction[]
  interactions  Interaction[]
  accesses      AgentAccess[]

  @@index([walletAddress])
}

//////////////////////////////////////////////////
// AGENT
//////////////////////////////////////////////////

model Agent {
  id              String        @id @default(auto()) @map("_id") @db.ObjectId
  agentId         String        @unique @default(cuid())

  // On-chain mapping
  contractAgentId Int?          // uint256 ID from contract
  txHash          String?       // deployment tx

  name            String        @unique
  description     String?
  metadataUri     String?

  ownerWallet     String
  owner           User          @relation(fields: [ownerWallet], references: [walletAddress])

  endpoint        String

  // Web3 fields
  tier            AgentTier
  pricing         String        // monthly price in wei
  upvotes         Int           @default(0)

  // Off-chain enhancements
  category        AgentCategory @default(Data)
  tags            String[]
  status          AgentStatus   @default(active)

  rating          Float         @default(0)
  ratingCount     Int           @default(0)

  calls           Int           @default(0)
  successRate     Float         @default(100)

  revenue         String        @default("0") // wei earned
  score           Float         @default(0)

  mcpSchema       Json?
  isVerified      Boolean       @default(false)

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  accesses        AgentAccess[]
  transactions    Transaction[]
  interactions    Interaction[]
  metrics         UsageMetrics?

  @@index([ownerWallet])
  @@index([status])
  @@index([category])
}

//////////////////////////////////////////////////
// ACCESS CONTROL (SUBSCRIPTIONS)
//////////////////////////////////////////////////

model AgentAccess {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId

  agentId     String
  userWallet  String

  expiresAt   DateTime
  isLifetime  Boolean  @default(false)

  agent       Agent    @relation(fields: [agentId], references: [agentId])
  user        User     @relation(fields: [userWallet], references: [walletAddress])

  createdAt   DateTime @default(now())

  @@unique([agentId, userWallet])
  @@index([agentId])
  @@index([userWallet])
}

//////////////////////////////////////////////////
// TRANSACTIONS (ALL TOKEN FLOWS)
//////////////////////////////////////////////////

model Transaction {
  id            String            @id @default(auto()) @map("_id") @db.ObjectId

  txHash        String            @unique

  type          TransactionType
  status        TransactionStatus @default(pending)

  agentId       String?
  agent         Agent?            @relation(fields: [agentId], references: [agentId])

  callerWallet  String
  caller        User              @relation(fields: [callerWallet], references: [walletAddress])

  ownerWallet   String?           // agent creator

  // TOKEN VALUES (ALL IN WEI STRING)
  totalAmount   String
  platformFee   String?
  creatorAmount String?

  createdAt     DateTime          @default(now())

  @@index([agentId])
  @@index([callerWallet])
  @@index([ownerWallet])
  @@index([type])
}

//////////////////////////////////////////////////
// INTERACTIONS (NO TOKEN COST)
//////////////////////////////////////////////////

model Interaction {
  id                  String            @id @default(auto()) @map("_id") @db.ObjectId

  agentId             String
  agent               Agent             @relation(fields: [agentId], references: [agentId])

  callerWallet        String?
  caller              User?             @relation(fields: [callerWallet], references: [walletAddress])

  task                String?
  response            String?

  latency             Int?
  status              InteractionStatus @default(success)

  parentInteractionId String?
  callDepth           Int               @default(0)

  errorMessage        String?

  createdAt           DateTime          @default(now())

  @@index([agentId])
  @@index([callerWallet])
  @@index([agentId, createdAt])
}

//////////////////////////////////////////////////
// USAGE METRICS
//////////////////////////////////////////////////

model UsageMetrics {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId

  agentId     String   @unique
  agent       Agent    @relation(fields: [agentId], references: [agentId])

  calls       Int      @default(0)
  successRate Float    @default(100)

  revenue     String   @default("0") // wei
  avgLatency  Float    @default(0)

  dailyCalls  Json     @default("{}")

  updatedAt   DateTime @updatedAt
}

//////////////////////////////////////////////////
// PLATFORM CONFIG (OPTIONAL BUT IMPORTANT)
//////////////////////////////////////////////////

model PlatformConfig {
  id               String @id @default("config")

  feeCollector     String

  standardFee      String
  professionalFee  String
  enterpriseFee    String

  updatedAt        DateTime @updatedAt
}

//////////////////////////////////////////////////
// GLOBAL STATS
//////////////////////////////////////////////////

model GlobalStats {
  id           String   @id @default("global")

  totalAgents  Int      @default(0)
  activeAgents Int      @default(0)

  totalCalls   Int      @default(0)
  totalRevenue String   @default("0") // wei

  updatedAt    DateTime @updatedAt
}